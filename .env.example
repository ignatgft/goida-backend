SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

AUTH_SECRET=replace-with-strong-random-secret
AUTH_TOKEN_TTL_SECONDS=86400
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_JWK_SET_URI=https://www.googleapis.com/oauth2/v3/certs

AI_PROVIDER=mock
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

RATES_PROVIDER=mock
RECEIPT_PROVIDER=mock
EXCHANGE_API_KEY=replace-me

DB_URL=jdbc:postgresql://localhost:5432/goida
DB_USERNAME=postgres
DB_PASSWORD=postgres
POSTGRES_DB=goida
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
JPA_DDL_AUTO=update
FLYWAY_ENABLED=false
JPA_SHOW_SQL=false
STORAGE_UPLOAD_DIR=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:8080

DOCKER_IMAGE_NAME=goida-backend
DOCKER_CONTAINER_PORT=8080
